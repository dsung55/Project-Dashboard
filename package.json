{
  "name": "project-dashboard",
  "version": "1.0.0",
  "description": "Local project management dashboard",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.projectdashboard.app",
    "productName": "Project Dashboard",
    "asar": false,
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Project Dashboard"
    },
    "files": [
      "**/*",
      "!data/**",
      "!.git/**",
      "!.claude/**",
      "!*.md",
      "!CHANGELOG.md"
    ]
  }
}
