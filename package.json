{
  "name": "project-dashboard",
  "version": "1.5.8",
  "description": "Local project management dashboard",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "electron": "node -e \"const {spawn}=require('child_process');spawn(require('electron'),['.'],{stdio:'inherit'})\"",
    "dist": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.projectdashboard.app",
    "productName": "Project Dashboard",
    "asar": false,
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "Project Dashboard (Windows).${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Project Dashboard"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "Project Dashboard (Mac).${ext}"
    },
    "dmg": {
      "title": "Project Dashboard",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "**/*",
      "!data/**",
      "!.git/**",
      "!.claude/**",
      "!*.md",
      "!CHANGELOG.md"
    ],
    "publish": {
      "provider": "github",
      "owner": "dsung55",
      "repo": "Project-Dashboard"
    }
  }
}
